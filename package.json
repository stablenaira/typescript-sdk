{
  "name": "@stablenaira/sdk",
  "version": "0.1.2",
  "description": "Official type-safe TypeScript SDK for StableNaira v1 API",
  "license": "MIT",
  "author": "StableNaira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stablenaira/typescript-sdk.git"
  },
  "homepage": "https://github.com/stablenaira/typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/stablenaira/typescript-sdk/issues"
  },
  "keywords": [
    "stablenaira",
    "sdk",
    "api",
    "typescript",
    "javascript",
    "stablecoin"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.6.3"
  }
}
